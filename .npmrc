# react-native is aliased to the react-native-tvos fork (so one codebase builds
# iOS, Android, and Apple TV). The fork publishes prerelease-tagged versions
# (e.g. 0.85.3-2), which strict peer resolution rejects, so relax it here. This
# also lets `npm install` run the postinstall patch (patches/) cleanly.
legacy-peer-deps=true
